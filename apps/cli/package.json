{
  "name": "umr-ai",
  "description": "The Unified Model Registry for your local AI apps",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "umr": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "lint": "biome check src",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@umr/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvanZhouDev/umr.git"
  },
  "keywords": [
    "ai",
    "local",
    "model",
    "llm"
  ],
  "author": "EvanZhouDev",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/EvanZhouDev/umr/issues"
  },
  "homepage": "https://github.com/EvanZhouDev/umr#readme"
}
